{
  "name": "shankar-multimedia-react",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://shankarmultimedia.com",
  "dependencies": {
    "@portabletext/react": "^6.2.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "framer-motion": "^10.12.4",
    "lucide-react": "^0.562.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-icons": "^4.8.0",
    "react-intersection-observer": "^9.4.3",
    "react-router-dom": "^6.30.2",
    "react-scripts": "5.0.1",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "ajv": "^8.17.1",
    "ajv-keywords": "^5.1.0",
    "react-snap": "^1.23.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "dev": "react-scripts start",
    "build": "react-scripts build",
    "postbuild": "react-snap",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src/**/*.{js,jsx}"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "reactSnap": {
    "source": "build",
    "minifyHtml": {
      "collapseWhitespace": false
    },
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "include": [
      "/",
      "/students-work",
      "/about",
      "/placements",
      "/contact",
      "/terms-conditions",
      "/privacy-policy",
      "/courses/advanced-graphic-and-uiux-design",
      "/courses/advanced-motion-graphic-and-video-editing",
      "/courses/advanced-3d-animation-and-modeling",
      "/courses/advanced-interior-design",
      "/courses/advanced-3d-animation-and-vfx",
      "/courses/advanced-web-design-and-development",
      "/courses/advanced-digital-marketing",
      "/courses/advanced-multimedia-animation-and-vfx"
    ]
  }
}